# 🧠 3️⃣ 집계 구조

## 1단계 — 기간 필터

```jsx
const filtered = filterByDate(rawData, timeRange);
```

---

## 2단계 — 곡별 그룹 집계

```jsx
function aggregateTrafficByTrack(data) {
  const result = {};

  data.forEach(row => {
    const id = row.videoId;
    const group = TRAFFIC_GROUP_MAP[row.trafficSourceType];

    if (!result[id]) {
      result[id] = {
        totalViews: 0,
        groups: {}
      };
    }

    result[id].totalViews += row.views;

    if (!result[id].groups[group]) {
      result[id].groups[group] = 0;
    }

    result[id].groups[group] += row.views;
  });

  return result;
}
```

---

## 3단계 — 비율 계산

```jsx
function calculateRatios(trackTraffic) {
  const total = trackTraffic.totalViews;
  const ratios = {};

  Object.entries(trackTraffic.groups).forEach(([group, views]) => {
    ratios[group] = views / total;
  });

  return ratios;
}
```

